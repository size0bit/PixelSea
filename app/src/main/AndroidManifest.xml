<?xml version="1.0" encoding="utf-8"?>
<!-- 
    AndroidManifest.xml - PixelSea 应用的主配置文件
    
    功能说明:
    - 定义应用的基本权限配置
    - 配置应用组件和元数据
    - 声明主启动 Activity
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
          xmlns:tools="http://schemas.android.com/tools">
    <!-- 权限声明：允许应用读取媒体图片 -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <!-- 权限声明：允许应用读取外部存储 (兼容旧版本 Android) -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <!-- 
        应用配置节点
        
        属性说明:
        - android:name: 自定义 Application 类，用于全局初始化
        - android:allowBackup: 允许通过 ADB 备份应用数据
        - android:dataExtractionRules: 数据提取规则引用
        - android:fullBackupContent: 完整备份内容配置引用
        - android:icon: 应用图标资源
        - android:label: 应用名称字符串资源
        - android:roundIcon: 圆形应用图标资源
        - android:supportsRtl: 支持从右到左的语言布局
        - android:theme: 应用默认主题样式
    -->
    <application
            android:name=".PixelSeaApplication"
            android:allowBackup="true"
            android:dataExtractionRules="@xml/data_extraction_rules"
            android:fullBackupContent="@xml/backup_rules"
            android:icon="@mipmap/ic_launcher"
            android:label="@string/app_name"
            android:roundIcon="@mipmap/ic_launcher_round"
            android:supportsRtl="true"
            android:theme="@style/Theme.PixelSea">
        <!-- 
            主 Activity 配置
            
            属性说明:
            - android:name: Activity 类名 (.MainActivity)
            - android:exported: 允许其他应用或系统启动此 Activity
            - android:label: Activity 显示的名称
            - android:theme: Activity 使用的主题
        -->
        <activity
                android:name=".MainActivity"
                android:exported="true"
                android:label="@string/app_name"
                android:theme="@style/Theme.PixelSea">
            <!-- 
                Intent 过滤器配置
                作用：声明 MainActivity 为应用的启动入口
                
                配置说明:
                - MAIN action: 表示这是应用的主入口点
                - LAUNCHER category: 表示此 Activity 应显示在应用启动器中
            -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>

                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>
    </application>

</manifest>